# Database (required)
DATABASE_URL=postgresql://user:password@localhost:5432/eomail

# Authentication (required)
SESSION_SECRET=change-me-to-a-random-secret-string

# Anthropic Claude (required for AI features)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Resend (required for email sending/receiving)
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_WEBHOOK_SECRET=whsec_your-webhook-secret-here

# Domain
DOMAIN=eomail.co

# Server
NODE_ENV=development
PORT=5000
