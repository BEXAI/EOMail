{
  "project": "Optimized Browser AI Agent with Render PostgreSQL",
  "version": "1.0",
  "created": "2026-03-07",
  "overview": {
    "description": "Full-stack AI agent system optimized for browser execution with Render PostgreSQL backend",
    "target": "EOMail application",
    "free_tier": true,
    "optimization_focus": ["latency", "cost", "reliability", "user_experience"]
  },
  "architecture": {
    "frontend": {
      "component": "Browser AI Agent",
      "technology": "React + TypeScript",
      "responsibilities": [
        "User input collection",
        "Local state management",
        "Real-time UI updates",
        "Request batching",
        "Response caching",
        "Streaming responses"
      ],
      "libraries": {
        "ai": "vercel/ai@latest",
        "streaming": "web-streams-polyfill",
        "state": "react-query",
        "cache": "idb-keyval"
      }
    },
    "backend": {
      "component": "Express API Server",
      "technology": "Node.js + Express",
      "responsibilities": [
        "LLM API orchestration",
        "Request routing",
        "Rate limiting",
        "Token management",
        "Session handling",
        "Database operations"
      ],
      "endpoints": [
        "/api/agent/chat",
        "/api/agent/stream",
        "/api/agent/complete",
        "/api/cache/get",
        "/api/cache/set",
        "/api/analytics/log"
      ]
    },
    "database": {
      "engine": "PostgreSQL",
      "provider": "Render",
      "tier": "free",
      "purpose": "Persistent storage for AI context, cache, and analytics"
    }
  },
  "database_schema": {
    "tables": {
      "ai_conversations": {
        "description": "Store complete conversation history",
        "columns": {
          "id": "UUID PRIMARY KEY",
          "user_id": "UUID FOREIGN KEY",
          "title": "TEXT",
          "created_at": "TIMESTAMP DEFAULT NOW()",
          "updated_at": "TIMESTAMP DEFAULT NOW()",
          "metadata": "JSONB (model, temperature, tokens, etc.)"
        },
        "indexes": ["user_id", "created_at"]
      },
      "ai_messages": {
        "description": "Individual messages in conversations",
        "columns": {
          "id": "UUID PRIMARY KEY",
          "conversation_id": "UUID FOREIGN KEY",
          "role": "ENUM('user', 'assistant')",
          "content": "TEXT",
          "tokens_used": "INTEGER",
          "created_at": "TIMESTAMP DEFAULT NOW()",
          "metadata": "JSONB"
        },
        "indexes": ["conversation_id", "role"]
      },
      "ai_cache": {
        "description": "Cache LLM responses for identical queries",
        "columns": {
          "id": "UUID PRIMARY KEY",
          "query_hash": "VARCHAR(64) UNIQUE",
          "prompt": "TEXT",
          "response": "TEXT",
          "model": "VARCHAR(50)",
          "tokens_saved": "INTEGER",
          "hits": "INTEGER DEFAULT 0",
          "expires_at": "TIMESTAMP",
          "created_at": "TIMESTAMP DEFAULT NOW()"
        },
        "indexes": ["query_hash", "expires_at", "hits"]
      },
      "ai_tokens": {
        "description": "Track token usage for billing and rate limiting",
        "columns": {
          "id": "UUID PRIMARY KEY",
          "user_id": "UUID FOREIGN KEY",
          "date": "DATE",
          "model": "VARCHAR(50)",
          "input_tokens": "INTEGER",
          "output_tokens": "INTEGER",
          "cost": "DECIMAL(10,4)",
          "created_at": "TIMESTAMP DEFAULT NOW()"
        },
        "indexes": ["user_id", "date", "model"]
      },
      "ai_agent_context": {
        "description": "Persistent context for agent memory",
        "columns": {
          "id": "UUID PRIMARY KEY",
          "user_id": "UUID FOREIGN KEY",
          "context_type": "VARCHAR(50)",
          "key": "VARCHAR(255)",
          "value": "JSONB",
          "priority": "INTEGER DEFAULT 0",
          "expires_at": "TIMESTAMP",
          "updated_at": "TIMESTAMP DEFAULT NOW()"
        },
        "indexes": ["user_id", "context_type", "expires_at"]
      },
      "ai_analytics": {
        "description": "Performance and usage analytics",
        "columns": {
          "id": "UUID PRIMARY KEY",
          "user_id": "UUID FOREIGN KEY",
          "event_type": "VARCHAR(50)",
          "model": "VARCHAR(50)",
          "latency_ms": "INTEGER",
          "tokens": "INTEGER",
          "success": "BOOLEAN",
          "error_type": "VARCHAR(100)",
          "metadata": "JSONB",
          "created_at": "TIMESTAMP DEFAULT NOW()"
        },
        "indexes": ["user_id", "event_type", "created_at"]
      }
    }
  },
  "optimization_strategies": {
    "frontend_optimizations": {
      "caching": {
        "strategy": "Multi-layer cache",
        "layers": [
          {
            "name": "Memory Cache",
            "duration": "5 minutes",
            "size_limit": "50 MB",
            "purpose": "Recent queries and responses"
          },
          {
            "name": "IndexedDB",
            "duration": "30 days",
            "size_limit": "500 MB",
            "purpose": "Persistent local cache"
          },
          {
            "name": "Server Cache (PostgreSQL)",
            "duration": "90 days",
            "size_limit": "unlimited",
            "purpose": "Shared cache across sessions"
          }
        ],
        "cache_key": "SHA256(prompt + model + temperature + top_p)"
      },
      "request_batching": {
        "description": "Batch multiple requests to reduce API calls",
        "strategy": "Debounce and group requests",
        "debounce_ms": 200,
        "batch_size_max": 10,
        "timeout_ms": 2000
      },
      "streaming_responses": {
        "enabled": true,
        "chunks": "token-by-token",
        "buffer_size": 5,
        "purpose": "Better UX, faster perceived response"
      },
      "local_inference": {
        "model": "TinyLlama or Mistral 7B (optional)",
        "storage": "IndexedDB",
        "use_case": "Fallback for offline, quick responses",
        "library": "transformers.js or ONNX.js"
      }
    },
    "backend_optimizations": {
      "llm_api_strategy": {
        "provider": "OpenAI (gpt-4-mini or gpt-3.5-turbo for cost)",
        "alternative_providers": ["Anthropic", "Groq", "Together AI"],
        "request_pooling": {
          "enabled": true,
          "pool_size": 5,
          "timeout_ms": 30000
        },
        "timeout_handling": {
          "fallback_model": "gpt-3.5-turbo",
          "retry_strategy": "exponential backoff",
          "max_retries": 3
        }
      },
      "rate_limiting": {
        "implementation": "Token bucket algorithm",
        "limits": {
          "free_tier": {
            "requests_per_minute": 10,
            "tokens_per_day": 100000
          },
          "pro_tier": {
            "requests_per_minute": 60,
            "tokens_per_day": 1000000
          }
        },
        "storage": "Redis-like (in PostgreSQL with triggers)"
      },
      "connection_pooling": {
        "library": "pg-boss or Bull for job queues",
        "pool_size": 10,
        "idle_timeout": 30000,
        "purpose": "Efficient database connections"
      },
      "caching_strategy": {
        "response_cache": {
          "ttl": "24 hours",
          "invalidation": "automatic on context change",
          "storage": "PostgreSQL ai_cache table"
        },
        "context_cache": {
          "ttl": "7 days",
          "size_limit": "10 MB per user",
          "storage": "PostgreSQL ai_agent_context table"
        }
      }
    },
    "database_optimizations": {
      "connection_pooling": {
        "implementation": "PgBouncer or pg connection pool",
        "min_connections": 2,
        "max_connections": 10,
        "idle_timeout": 900
      },
      "query_optimization": {
        "strategies": [
          "Indexes on frequently queried columns",
          "Materialized views for analytics",
          "Partitioning by date for large tables",
          "EXPLAIN ANALYZE for query planning"
        ],
        "critical_queries": [
          "Cache lookups (ai_cache by query_hash)",
          "Message retrieval (ai_messages by conversation_id)",
          "Token counting (ai_tokens by user_id and date)"
        ]
      },
      "vacuum_and_maintenance": {
        "autovacuum": true,
        "analyze_frequency": "daily",
        "index_maintenance": "weekly"
      },
      "storage_optimization": {
        "compression": "enabled for JSONB columns",
        "archival_strategy": "Move old conversations to archive table after 6 months",
        "retention_policy": "Delete cache entries after 90 days"
      }
    },
    "cost_optimization": {
      "free_tier_strategy": {
        "database": "Render free PostgreSQL (512 MB)",
        "api_calls": "Prioritize efficient models (gpt-3.5-turbo)",
        "caching": "Aggressive caching to reduce API calls by 70%",
        "batch_processing": "Off-peak batch jobs for non-critical tasks"
      },
      "token_reduction": {
        "strategies": [
          "Use smaller models for simple tasks",
          "Implement context pruning (keep only recent messages)",
          "Compress prompts with templates",
          "Use embeddings for semantic search instead of re-processing",
          "Cache system prompts and instructions"
        ],
        "estimated_savings": "40-50% token reduction"
      },
      "api_alternatives": {
        "low_cost_models": [
          "OpenAI gpt-3.5-turbo ($0.0015/$0.002 per 1K tokens)",
          "Anthropic Claude 3 Haiku ($0.25/$1.25 per 1M tokens)",
          "Groq (free tier available, very fast)",
          "Mistral 7B (open source, self-hosted option)"
        ],
        "recommendation": "Use Groq for fast, free tier initially"
      }
    }
  },
  "implementation_roadmap": {
    "phase_1_foundation": {
      "timeline": "Week 1-2",
      "tasks": [
        {
          "task": "Set up database schema",
          "subtasks": [
            "Run migrations for all 6 tables",
            "Create indexes",
            "Set up constraints and triggers"
          ],
          "effort": "4 hours"
        },
        {
          "task": "Create AI API endpoints",
          "subtasks": [
            "POST /api/agent/chat (streaming)",
            "GET /api/cache/get",
            "POST /api/cache/set",
            "Error handling and validation"
          ],
          "effort": "8 hours"
        },
        {
          "task": "Build browser UI component",
          "subtasks": [
            "Chat interface",
            "Input handling",
            "Response rendering",
            "Loading states"
          ],
          "effort": "6 hours"
        }
      ],
      "deliverable": "Basic AI chat working end-to-end"
    },
    "phase_2_optimization": {
      "timeline": "Week 3-4",
      "tasks": [
        {
          "task": "Implement caching layer",
          "subtasks": [
            "Memory cache (in React)",
            "IndexedDB persistence",
            "PostgreSQL cache table",
            "Cache invalidation logic"
          ],
          "effort": "10 hours"
        },
        {
          "task": "Add streaming responses",
          "subtasks": [
            "Server streaming endpoint",
            "Browser stream parsing",
            "Token-by-token rendering",
            "Fallback for non-streaming"
          ],
          "effort": "6 hours"
        },
        {
          "task": "Rate limiting",
          "subtasks": [
            "Token bucket implementation",
            "Per-user limits",
            "Quota tracking in DB",
            "API rejection handling"
          ],
          "effort": "6 hours"
        }
      ],
      "deliverable": "Production-ready with optimization"
    },
    "phase_3_advanced": {
      "timeline": "Week 5-6",
      "tasks": [
        {
          "task": "Memory/context management",
          "subtasks": [
            "Conversation context storage",
            "Context pruning algorithms",
            "Semantic search with embeddings",
            "Long-term memory system"
          ],
          "effort": "12 hours"
        },
        {
          "task": "Analytics and monitoring",
          "subtasks": [
            "Event logging system",
            "Cost tracking dashboard",
            "Performance metrics",
            "Error rate monitoring"
          ],
          "effort": "8 hours"
        },
        {
          "task": "Multi-provider support",
          "subtasks": [
            "Abstract LLM interface",
            "OpenAI integration",
            "Groq integration (optional)",
            "Anthropic integration (optional)"
          ],
          "effort": "8 hours"
        }
      ],
      "deliverable": "Enterprise-grade AI system"
    }
  },
  "api_endpoints": {
    "chat_streaming": {
      "method": "POST",
      "path": "/api/agent/chat",
      "request": {
        "message": "string",
        "conversation_id": "uuid (optional)",
        "model": "string (default: gpt-3.5-turbo)",
        "temperature": "number (0-2)",
        "stream": "boolean (default: true)"
      },
      "response": "EventStream or JSON",
      "performance": {
        "target_latency_ms": 500,
        "cache_hit_rate_target": "70%"
      }
    },
    "cache_get": {
      "method": "GET",
      "path": "/api/cache/:hash",
      "response": "{ cached_response, hit_count, age_ms }",
      "performance": {
        "target_latency_ms": 50
      }
    },
    "cache_set": {
      "method": "POST",
      "path": "/api/cache",
      "request": {
        "query_hash": "string",
        "response": "string",
        "ttl_hours": "number"
      },
      "response": "{ success, cache_id }"
    },
    "analytics": {
      "method": "POST",
      "path": "/api/analytics/log",
      "request": {
        "event_type": "string",
        "latency_ms": "number",
        "tokens": "number",
        "success": "boolean",
        "metadata": "object"
      },
      "response": "{ logged }"
    }
  },
  "monitoring_and_metrics": {
    "key_metrics": [
      {
        "name": "Cache Hit Rate",
        "target": "70%+",
        "query": "SELECT hits / (hits + misses) FROM ai_cache_stats"
      },
      {
        "name": "Average Latency",
        "target": "<500ms",
        "query": "SELECT AVG(latency_ms) FROM ai_analytics"
      },
      {
        "name": "Token Efficiency",
        "target": "<50% of baseline",
        "metric": "Average tokens per request vs. no caching"
      },
      {
        "name": "Cost Per Request",
        "target": "<$0.01 (free tier)",
        "query": "SELECT SUM(cost) / COUNT(*) FROM ai_tokens"
      },
      {
        "name": "Error Rate",
        "target": "<1%",
        "query": "SELECT COUNT(*) WHERE success = false FROM ai_analytics"
      }
    ],
    "alerts": [
      {
        "condition": "Error rate > 5%",
        "action": "Alert via email + Slack"
      },
      {
        "condition": "Daily cost > $10",
        "action": "Throttle requests, alert user"
      },
      {
        "condition": "Database size > 400MB",
        "action": "Trigger archival process"
      },
      {
        "condition": "API latency > 3s",
        "action": "Switch to fallback model"
      }
    ]
  },
